<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - <%= user.name %></title>
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-linear-to-br from-zinc-950 via-zinc-900 to-zinc-950 min-h-screen text-white antialiased selection:bg-blue-500 selection:text-white">

    <!-- Main Wrapper -->
    <div class="w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col gap-10">
        
        <!-- Header Section -->
        <header class="w-full flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 pb-6 border-b border-zinc-800/80">
            <div>
                <h1 class="text-3xl lg:text-4xl font-extrabold tracking-tight bg-linear-to-r from-white via-zinc-200 to-zinc-400 bg-clip-text text-transparent">
                    Hello, <%= user.name %>
                </h1>
                <p class="text-zinc-400 text-sm mt-1">Welcome back to your dashboard feed.</p>
            </div>
            <a href="/logout" class="px-5 py-2.5 text-sm bg-red-950/40 text-red-400 hover:bg-red-900/60 border border-red-800/50 rounded-xl transition-all duration-300 active:scale-95 font-semibold shadow-lg shadow-red-950/20">
                Logout Account
            </a>
        </header>
       
        <!-- Create Post Section -->
        <section class="w-full max-w-xl mx-auto bg-zinc-900/40 border border-zinc-800/80 backdrop-blur-md p-6 rounded-2xl shadow-xl shadow-black/20 flex flex-col gap-5">
            <h2 class="text-xl font-bold tracking-tight text-zinc-200">Create a New Post</h2>
            
            <form action="/post" method="post" class="flex flex-col gap-4">
                <textarea name="content" rows="4" placeholder="What's on your mind?..." 
                    class="w-full outline-none px-4 py-3 rounded-xl bg-zinc-950/50 text-white placeholder-zinc-500 border border-zinc-800 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all duration-300 shadow-inner resize-none"></textarea>
                
                <button type="submit" class="self-end bg-linear-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white font-semibold py-2.5 px-6 rounded-xl transition-all duration-300 shadow-lg shadow-blue-600/10 hover:shadow-blue-500/20 active:scale-[0.98] cursor-pointer">
                    Publish Post
                </button>
            </form>
        </section>

        <!-- Feed Section -->
        <main class="w-full flex flex-col gap-6">
            <div class="flex items-center gap-3">
                <h2 class="text-xl font-bold tracking-tight text-zinc-300">Your Timeline Feed</h2>
                <div class="h-px flex-1 bg-zinc-800/80"></div>
            </div>

            <!-- Responsive Grid Container -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
                <% user.post.reverse().forEach((post) => { %>
                    <div class="bg-zinc-900/30 border border-zinc-800/60 backdrop-blur-sm rounded-2xl p-6 flex flex-col justify-between shadow-lg hover:border-zinc-700/50 transition-all duration-300 group">
                        
                        <!-- Card Header & Content -->
                        <div class="flex flex-col gap-3">
                            <div class="flex items-center justify-between">
                                <span class="text-sm font-bold text-blue-400 tracking-wide flex items-center gap-1">
                                    <span class="opacity-60">@</span><%= user.name %>
                                </span>
                                <!-- Small conditional badge for likes count -->
                                <span class="text-xs px-2.5 py-1 border rounded-full font-medium transition-colors <%= post.likes.length > 0 ? 'bg-emerald-500/10 text-emerald-400  border-emerald-500/20' : 'bg-zinc-800/50 text-zinc-500  border-zinc-800' %>">
                                    <%= post.likes.length %> <%= post.likes.length === 1 ? 'Like' : 'Likes' %>
                                </span>
                            </div>
                            <p class="text-zinc-300 text-sm leading-relaxed whitespace-pre-wrap"><%= post.content %></p>
                        </div>

                        <!-- Actions Footer -->
                        <div class="mt-6 pt-4 border-t border-zinc-800/60 flex justify-between items-center text-xs font-semibold tracking-wider uppercase">
                            <a href="/like/<%= post._id %>" class="transition-colors duration-200 px-3 py-1.5 rounded-lg bg-zinc-800/40 hover:bg-zinc-800/80 <%= post.likes.indexOf(user._id) === -1 ? 'text-blue-400 hover:text-blue-300':'text-rose-400 hover:text-rose-300' %>">
                                <%= post.likes.indexOf(user._id) === -1 ? "👍 Like" :"❤️ Unlike" %>
                            </a>
                            <a href="/edit/<%= post._id %>" class="text-zinc-400 hover:text-white transition-colors duration-200 px-3 py-1.5 rounded-lg bg-zinc-800/20 hover:bg-zinc-800/60 border border-zinc-800/40">
                                📝 Edit
                            </a>
                        </div>

                    </div>
                <% }) %>
            </div>
        </main>
        
    </div>
</body>
</html>