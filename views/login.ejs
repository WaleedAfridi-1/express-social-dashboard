<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Account</title>
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-linear-to-br from-zinc-950 via-zinc-900 to-zinc-950 min-h-screen text-white antialiased selection:bg-blue-500 selection:text-white">

    <!-- Main Container -->
    <div class="w-full min-h-screen px-6 py-8 flex flex-col items-center justify-between md:justify-start md:gap-16">
        
        <!-- Top Navigation / Go to Sign Up -->
        <div class="w-full max-w-4xl flex justify-between items-center">
            <a href="/" class="px-5 py-2 text-sm bg-zinc-800/80 hover:bg-zinc-700/80 border border-zinc-700/50 rounded-lg backdrop-blur-sm transition-all duration-300 active:scale-95 font-medium flex items-center gap-2 shadow-lg shadow-black/20">
                Create Account <span class="text-blue-400">&rarr;</span>
            </a>
        </div>

        <!-- Form Card Container -->
        <div class="w-full max-w-md my-auto md:my-0 bg-zinc-900/40 border border-zinc-800/80 backdrop-blur-md p-8 rounded-2xl shadow-2xl shadow-black/40 flex flex-col gap-8">
            
            <!-- Header -->
            <div class="text-center">
                <h1 class="text-3xl font-extrabold tracking-tight bg-linear-to-r from-white via-zinc-200 to-zinc-400 bg-clip-text text-transparent">
                    Login Account
                </h1>
                <p class="text-zinc-400 text-sm mt-2">Welcome back! Please enter your details.</p>
            </div>

            <!-- Form -->
            <form action="/login" method="post" class="flex flex-col gap-5">
                
                <!-- Email Input -->
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-zinc-400 uppercase tracking-wider pl-1">Email Address</label>
                    <input class="w-full px-4 py-3 rounded-xl outline-none border border-zinc-800 bg-zinc-950/50 text-white placeholder-zinc-500 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all duration-300 shadow-inner" 
                           placeholder="you@example.com" required type="email" name="email">
                </div>

                <!-- Password Input -->
                <div class="flex flex-col gap-1.5">
                    <div class="flex justify-between items-center px-1">
                        <label class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Password</label>
                    </div>
                    <input class="w-full px-4 py-3 rounded-xl outline-none border border-zinc-800 bg-zinc-950/50 text-white placeholder-zinc-500 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all duration-300 shadow-inner" 
                           placeholder="••••••••" required type="password" name="password">
                </div>

                <!-- Submit Button -->
                <button type="submit" class="w-full mt-2 bg-linear-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white font-bold py-3 px-6 rounded-xl transition-all duration-300 shadow-lg shadow-blue-600/20 hover:shadow-blue-500/30 active:scale-[0.98] cursor-pointer text-center">
                    Sign In
                </button>
            </form>

            <!-- Footer Text -->
            <p class="text-xs text-center text-zinc-500">
                Secure login with industry standard encryption.
            </p>
        </div>

        <!-- Dummy element for layout balance -->
        <div class="hidden md:block"></div>
    </div>
</body>
</html>